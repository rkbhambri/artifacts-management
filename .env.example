# Copy to .env to override docker-compose defaults.
# Shared internal API key required for artifact uploads (write endpoints).
API_KEY=dev-internal-api-key

# CORS origin allowed by the backend (the dashboard URL).
CORS_ORIGIN=http://localhost:3000

# Max artifact upload size in megabytes.
MAX_UPLOAD_MB=25

# Backend URL as reached from the browser (baked into the frontend at build).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend URL as reached from the frontend container during SSR. Inside
# docker-compose the frontend cannot use localhost, so it talks to the backend
# over the compose network via its service name.
INTERNAL_API_URL=http://backend:4000
